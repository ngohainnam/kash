generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CsvFile {
  id           String   @id @default(cuid())
  userId       String
  fileName     String
  uploadedAt   DateTime @default(now())
  transactions String   // JSON string of Transaction[]

  @@index([userId])
}
